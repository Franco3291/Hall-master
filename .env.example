# === REQUIRED ENVIRONMENT VARIABLES FOR RENDER DEPLOYMENT ===

# Database: Set to your PostgreSQL connection string (provided by Render)
# When not set, defaults to local SQLite (campus_navigation.db)
DATABASE_URL=postgresql://user:password@host:5432/smart_campus

# Admin credentials for the campus management system
ADMIN_PASSWORD=your_secure_admin_password_here
ADMIN_USERNAME=admin

# === OPTIONAL SETTINGS ===
# These are already configured in main.py with sensible defaults
# PORT is automatically provided by Render, no need to set it manually